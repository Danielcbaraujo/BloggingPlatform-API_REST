@baseUrl = https://bookish-potato-6qw7vggv9pjfrx4w-3000.app.github.dev
@contentType = application/json

### ==========================================
### API BLOGGING PLATFORM
### ==========================================

### Teste da API
GET {{baseUrl}}/

###

### Listar todos os posts
GET {{baseUrl}}/posts

###

### Buscar post por ID
GET {{baseUrl}}/posts/3

###

### Criar um novo post
POST {{baseUrl}}/posts
Content-Type: {{contentType}}

{
    "title": "Aprendendo REST Client",
    "content": "Este post foi criado utilizando o REST Client do VS Code.",
    "category": "Programação",
    "tags": [
        "node",
        "express",
        "prisma"
    ]
}

###

### Atualizar um post
PUT {{baseUrl}}/posts/6
Content-Type: {{contentType}}

{
    "title": "Post Atualizado",
    "content": "Conteúdo atualizado utilizando REST Client.",
    "category": "Backend",
    "tags": [
        "express",
        "node",
        "prisma",
        "rest-client"
    ]
}

###

### Deletar um post
DELETE {{baseUrl}}/posts/1

###

